# ============================================
# Food Store Backend - Variables de Entorno
# ============================================
# Copiar este archivo a .env y completar los valores
#
# 🐳 LEVANTAR CON DOCKER (recomendado)
# ------------------------------------
# Requisito: Docker Desktop instalado
#
#   docker-compose up
#
# Levanta automáticamente:
#   - PostgreSQL en localhost:5432
#   - Backend FastAPI en localhost:8000
#   - Frontend Vite en localhost:5173
#   - Migraciones + seed de datos
#
# Para cargar tu dump de BD:
#   docker-compose up -d db
#   psql -h localhost -U postgres -d foodstore < foodstore_dump.sql
#   docker-compose up
#
# 🚀 LEVANTAR MANUAL (sin Docker)
# ------------------------------------
# Requisito: PostgreSQL, Python 3.11+, Node.js 18+
#
#   cd backend
#   pip install -r requirements.txt
#   alembic upgrade head
#   python -m app.db.seed
#   uvicorn app.main:app --reload
#
#   cd frontend
#   npm install
#   npm run dev

# ---------- Base de Datos ----------
# Con Docker: postgresql+asyncpg://postgres:postgres@db:5432/foodstore
# Sin Docker: postgresql+asyncpg://postgres:postgres@localhost:5432/foodstore
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/foodstore

# ---------- JWT & Seguridad ----------
SECRET_KEY=tu-clave-secreta-super-larga-cambiar-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- CORS ----------
CORS_ORIGINS=["http://localhost:5173"]

# ---------- MercadoPago ----------
MP_ACCESS_TOKEN=TEST-xxx
MP_PUBLIC_KEY=TEST-xxx
MP_NOTIFICATION_URL=https://tu-dominio.com/api/v1/webhooks/mercadopago

# ---------- Admin Seed ----------
ADMIN_EMAIL=admin@foodstore.com
ADMIN_PASSWORD=admin123456
